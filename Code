        "# Import necessary libraries\n",
        "import pandas as pd\n",
        "from scipy.stats import chi2_contingency\n",
        "import seaborn as sns\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Sample DataFrame creation (replace this with your actual DataFrame)\n",
        "data = {\n",
        "    'Severity_Moderate': ['Mild', 'Moderate', 'Mild', 'Severe', 'Moderate', 'None', 'Mild', 'Severe'],\n",
        "    'Age_0-9': [1, 0, 1, 0, 0, 1, 1, 0],\n",
        "    'Age_10-19': [0, 1, 0, 1, 1, 0, 0, 0],\n",
        "    'Age_20-24': [0, 0, 0, 0, 0, 0, 0, 0],\n",
        "    'Age_25-59': [0, 0, 1, 0, 0, 0, 1, 1],\n",
        "    'Age_60+': [0, 0, 0, 0, 0, 0, 0, 0]\n",
        "}\n",
        "df = pd.DataFrame(data)\n",
        "\n",
        "# Step 1: Create a contingency table\n",
        "contingency_table = pd.crosstab(df['Severity_Moderate'], df['Age_0-9'])\n",
        "print(\"Contingency Table:\\n\", contingency_table)\n",
        "\n",
        "# Step 2: Perform the Chi-Square test\n",
        "chi2, p, _, _ = chi2_contingency(contingency_table)\n",
        "print(f\"\\nChi-Square statistic: {chi2}, p-value: {p}\")\n",
        "\n",
        "# Step 3: Visualize the relationship using a count plot\n",
        "sns.countplot(data=df, x='Age_0-9', hue='Severity_Moderate')\n",
        "plt.title('Severity Levels by Age Group (0-9)')\n",
        "plt.xlabel('Age Group (0-9)')\n",
        "plt.ylabel('Count')\n",
        "plt.legend(title='Severity Level')\n",
        "plt.show()\n"
      ]
    },
